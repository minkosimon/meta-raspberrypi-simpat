# short-description: Create Raspberry Pi boot SD card for NFS rootfs
# long-description: Creates a boot-only SD card image. The root filesystem is
# expected to be exported over NFS.

part /boot --source bootimg-partition --ondisk ${SIMPAT_WIC_DISK_DEV} --fstype=vfat --label ${SIMPAT_WIC_BOOT_PARTITION_LABEL} --active --align ${SIMPAT_WIC_PARTITION_ALIGN} --size ${SIMPAT_WIC_BOOT_PARTITION_SIZE}

bootloader --ptable msdos