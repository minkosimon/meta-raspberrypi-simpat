# short-description: Create Raspberry Pi SD card image with local root filesystem
# long-description: Creates a partitioned SD card image with a VFAT boot
# partition and a Linux rootfs partition.

part /boot --source bootimg-partition --ondisk ${SIMPAT_WIC_DISK_DEV} --fstype=vfat --label ${SIMPAT_WIC_BOOT_PARTITION_LABEL} --active --align ${SIMPAT_WIC_PARTITION_ALIGN} --size ${SIMPAT_WIC_BOOT_PARTITION_SIZE}
part / --source rootfs --ondisk ${SIMPAT_WIC_DISK_DEV} --fstype=${SIMPAT_WIC_ROOTFS_PARTITION_FSTYPE} --label ${SIMPAT_WIC_ROOTFS_PARTITION_LABEL} --align ${SIMPAT_WIC_PARTITION_ALIGN} --use-uuid

bootloader --ptable msdos