# Auto-generated by Yocto network-config class
# Virtual interface: {{ interface.name }} (type: {{ kind }})
# Do NOT edit manually - changes will be overwritten!

{% if kind == 'vlan' %}
[NetDev]
Name={{ interface.name }}
Kind=vlan
{% if interface.get('description') %}
Description={{ interface.description }}
{% endif %}

[VLAN]
Id={{ interface.get('id', interface.get('vlan_id', 0)) }}

{% elif kind == 'bridge' %}
[NetDev]
Name={{ interface.name }}
Kind=bridge
{% if interface.get('description') %}
Description={{ interface.description }}
{% endif %}
{% if interface.get('mtu') %}
MTUBytes={{ interface.mtu }}
{% endif %}

{% if interface.get('stp') or interface.get('forward_delay') or interface.get('hello_time') or interface.get('max_age') %}
[Bridge]
{% if interface.get('stp') %}
STP=yes
{% if interface.get('forward_delay') %}
ForwardDelaySec={{ interface.forward_delay }}
{% endif %}
{% if interface.get('hello_time') %}
HelloTimeSec={{ interface.hello_time }}
{% endif %}
{% if interface.get('max_age') %}
MaxAgeSec={{ interface.max_age }}
{% endif %}
{% else %}
STP=no
{% endif %}
{% endif %}

{% elif kind == 'bond' %}
[NetDev]
Name={{ interface.name }}
Kind=bond
{% if interface.get('description') %}
Description={{ interface.description }}
{% endif %}
{% if interface.get('mtu') %}
MTUBytes={{ interface.mtu }}
{% endif %}

[Bond]
Mode={{ interface.get('mode', 'balance-alb') }}
MIIMonitorSec={{ interface.get('miimon', 100) }}ms
{% if interface.get('downdelay') %}
DownDelaySec={{ interface.downdelay }}ms
{% endif %}
{% if interface.get('updelay') %}
UpDelaySec={{ interface.updelay }}ms
{% endif %}
{% if interface.get('primary') %}
PrimaryReselectPolicy=better
PrimarySlaveDevice={{ interface.primary }}
{% endif %}

{% endif %}
