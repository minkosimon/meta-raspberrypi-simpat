# Auto-generated by Yocto network-config class
# Configuration for interface: {{ interface.name }} (index: {{ index }})
# Do NOT edit manually - changes will be overwritten!

[Match]
Name={{ interface.name }}

[Link]
{% if interface.get('mtu') %}
MTUBytes={{ interface.mtu }}
{% endif %}
{% if interface.get('description') %}
Alias={{ interface.description }}
{% endif %}

[Network]
{% if interface.get('dhcp4') %}
DHCP=ipv4
{% endif %}
{% if interface.get('dhcp6') %}
DHCP=ipv6
{% endif %}
{% if not interface.get('dhcp4') and not interface.get('dhcp6') %}
{% if interface.get('ipv4') %}
{% for addr in interface.ipv4 %}
Address={{ addr }}
{% endfor %}
{% endif %}
{% if interface.get('ipv6') %}
{% for addr in interface.ipv6 %}
Address={{ addr }}
{% endfor %}
{% endif %}
{% endif %}

{% if interface.get('gateway4') %}
Gateway={{ interface.gateway4 }}
{% endif %}
{% if interface.get('gateway6') %}
IPv6Gateway={{ interface.gateway6 }}
{% endif %}

{% if interface.get('dns') %}
{% for dns_server in interface.dns %}
DNS={{ dns_server }}
{% endfor %}
{% endif %}

{% if interface.get('dns_search') %}
Domains={{ interface.dns_search | join(' ') }}
{% endif %}

{% if interface.get('ntp') %}
{% for ntp_server in interface.ntp %}
NTP={{ ntp_server }}
{% endfor %}
{% endif %}

{% if interface.get('routes') %}
{% for route in interface.routes %}
[Route]
Destination={{ route.destination }}
{% if route.get('gateway') %}
Gateway={{ route.gateway }}
{% endif %}
{% if route.get('metric') %}
Metric={{ route.metric }}
{% endif %}
{% endfor %}
{% endif %}

# Bridge members
{% if interface.get('kind') == 'bridge' and interface.get('members') %}
{% for member in interface.members %}
Bridge={{ member }}
{% endfor %}
{% endif %}

# Bond members
{% if interface.get('kind') == 'bond' and interface.get('members') %}
{% for member in interface.members %}
Bond={{ member }}
{% endfor %}
{% endif %}

# VLAN configuration
{% if interface.get('kind') == 'vlan' %}
{% if interface.get('link') %}
# Reference to parent interface
# Bind={{ interface.link }}
{% endif %}
{% endif %}

# Interface options
{% if interface.get('multicast') == false %}
Multicast=off
{% endif %}
{% if interface.get('arp') == false %}
ARP=off
{% endif %}
{% if interface.get('link_local') %}
LinkLocalAddressing={{ interface.link_local }}
{% endif %}
